{
  "name": "job-agent-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:api",
    "test:coverage": "npm run test:api:coverage",
    "test:watch": "vitest",
    "test:api": "vitest run --config vitest.node.config.js",
    "test:api:coverage": "vitest run --config vitest.node.config.js --coverage",
    "test:dom": "vitest run",
    "test:dom:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.1.2",
    "baseline-browser-mapping": "^2.9.17",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "vite": "^7.2.2",
    "vitest": "^4.1.2"
  }
